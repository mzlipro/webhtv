<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/display_option_bg_selected" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/display_option_stroke_selected" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/display_option_bg_focused" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/display_option_stroke_selected" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/display_option_bg_focused" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/display_option_stroke_selected" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/display_option_bg_default" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/display_option_stroke_default" />
        </shape>
    </item>
</selector>
